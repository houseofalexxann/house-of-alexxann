// House of Alexxann — Phase 1 data model (PRD §9).
// Dev runs on embedded PostgreSQL; production points DATABASE_URL at any
// managed Postgres. Birth data is sensitive PII — see PRD §11.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  seeker
  client
  admin
}

enum ChartSystem {
  western
  vedic
}

enum SessionFormat {
  video
  phone
  in_person
}

enum BookingStatus {
  pending
  confirmed
  canceled
  completed
}

enum PaymentStatus {
  unpaid
  paid
  refunded
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         Role     @default(seeker)
  passwordHash String?
  /** Premium membership flag — admin-toggled until Stripe subscriptions land. */
  isMember     Boolean  @default(false)
  /** Time-boxed access (free trials, comps): member while now < memberUntil. */
  memberUntil     DateTime?
  /** One free trial per account, ever. */
  trialRedeemedAt DateTime?
  createdAt    DateTime @default(now())
  profiles     BirthProfile[]
}

/**
 * Promo codes (admin-created): percent/amount off readings or membership,
 * or a free-trial grant of N days. Codes are stored uppercase.
 */
model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  /** "readings" | "membership" | "trial" */
  kind           String
  percentOff     Int?
  amountOffCents Int?
  trialDays      Int?
  maxRedemptions Int?
  redemptions    Int       @default(0)
  expiresAt      DateTime?
  active         Boolean   @default(true)
  note           String?
  createdAt      DateTime  @default(now())
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  /** Markdown-lite body (paragraphs + **bold**), rendered by RichText. */
  body        String
  premium     Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
}

model BirthProfile {
  id         String    @id @default(cuid())
  name       String
  // Local birth data as entered + resolved place.
  birthDate  String // YYYY-MM-DD (local)
  birthTime  String? // HH:mm (local); null = time unknown
  timeKnown  Boolean   @default(true)
  placeLabel String
  latitude   Float
  longitude  Float
  timezone   String
  utc        DateTime // resolved birth instant
  notes      String?
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  charts     Chart[]
  createdAt  DateTime  @default(now())
}

model Chart {
  id             String       @id @default(cuid())
  birthProfileId String
  birthProfile   BirthProfile @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)
  system         ChartSystem
  houseSystem    String
  ayanamsa       String?
  payload        Json
  computedAt     DateTime     @default(now())
}

model Service {
  id              String    @id @default(cuid())
  slug            String    @unique
  type            String // natal | transit | vedic
  title           String
  durationMinutes Int
  priceCents      Int
  active          Boolean   @default(true)
  bookings        Booking[]
}

model Booking {
  id            String        @id @default(cuid())
  // Public lookup token so the confirmation page needs no account.
  token         String        @unique @default(cuid())
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id])
  clientName    String
  clientEmail   String
  clientPhone   String?
  format        SessionFormat
  startUtc      DateTime
  endUtc        DateTime
  clientTz      String
  status        BookingStatus @default(pending)
  paymentStatus PaymentStatus @default(unpaid)
  // Sliding scale: which tier was chosen and the actual amount.
  priceCents    Int
  priceTier     String        @default("standard")
  /** Promo code applied at booking (normalized uppercase), for the ledger. */
  promoCode     String?
  paymentMode   String? // "stripe" | "mock"
  stripeSessionId String?     @unique
  // Format-specific delivery detail (video link / phone / address).
  meetingDetail String?
  // Optional birth data so Alexandria can prepare the chart.
  birthDate     String?
  birthTime     String?
  birthPlace    String?
  notes         String?
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  createdAt     DateTime      @default(now())

  @@index([startUtc])
  @@index([status, startUtc])
  // A partial unique index (active bookings only) is added by migration
  // 20260710_booking_slot_guard — it enforces one live booking per
  // (serviceId, startUtc) at the database level, closing the check-then-insert
  // race. Prisma can't express a partial index, so it lives in raw SQL.
}

// Weekly availability windows in the practitioner's timezone.
model AvailabilityRule {
  id          String  @id @default(cuid())
  weekday     Int // 0 = Sunday … 6 = Saturday
  startMinute Int // minutes from local midnight
  endMinute   Int
  active      Boolean @default(true)
}

// Date-specific overrides: block a day or open extra hours.
model AvailabilityException {
  id          String  @id @default(cuid())
  date        String // YYYY-MM-DD in practitioner tz
  blocked     Boolean @default(true)
  startMinute Int?
  endMinute   Int?
  note        String?
}

// Practitioner settings (buffer, lead time, timezone, horizon).
model Setting {
  key   String @id
  value String
}

// ————————————————————————————————————————————————————————————————————————
// KNOWLEDGE LAYER (architecture review §9, approved 2026-07-12).
// One spine: every piece of knowledge knows where it came from and how sure
// it is. Concepts are the hub; claims carry epistemic status; citations
// point at editions with locators.
// ————————————————————————————————————————————————————————————————————————

enum EpistemicStatus {
  doctrine       // what a historical source states
  scholarship    // what modern scholars conclude about sources/history
  evidence       // empirically supported findings (science, replicated research)
  theory         // structured frameworks/arguments not empirically settled
  observation    // patterns observed in practice ("I have observed…")
  synthesis      // Alexandria's own view
  simplification // teaching shorthand
  experimental   // ideas being tested
}

enum SourceKind {
  primary
  translation
  scholarship
  course
  podcast
  article
}

enum RightsStatus {
  in_copyright
  public_domain
  own_work
}

enum Tradition {
  hellenistic
  medieval
  renaissance
  vedic
  modern
  human_design
  tarot
  // Disciplines beyond astrology proper — the corpus is interdisciplinary.
  astronomy
  philosophy
  psychology
  mythology
  design
  methodology
}

enum CrossRefType {
  derives_from
  contrasts
  refines
  translates_to
  see_also
}

model Author {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  lifespan  String? // "787–886 CE", "b. 1974"
  tradition Tradition?
  bio       String?
  sources   SourceAuthor[]
}

model Source {
  id        String       @id @default(cuid())
  slug      String       @unique
  title     String
  kind      SourceKind
  year      Int?
  publisher String?
  language  String       @default("en")
  rights    RightsStatus
  notes     String?
  authors   SourceAuthor[]
  editions  Edition[]
  citations Citation[]
}

model SourceAuthor {
  sourceId String
  authorId String
  role     String @default("author") // author | translator | editor
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([sourceId, authorId, role])
}

model Edition {
  id         String    @id @default(cuid())
  sourceId   String
  source     Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  translator String?
  year       Int?
  publisher  String?
  isbn       String?
  notes      String?
  excerpts   Excerpt[]
  citations  Citation[]
}

model Excerpt {
  id         String     @id @default(cuid())
  editionId  String
  edition    Edition    @relation(fields: [editionId], references: [id], onDelete: Cascade)
  /// Granular locator: page for modern books; book/chapter/section for
  /// classical texts so the citation survives across editions.
  locator    String
  /// Short quoted text only (fair use) — never full-text reproduction.
  text       String
  language   String     @default("en")
  verifiedAt DateTime? // second-pass QA against the physical source
  citations  Citation[]
}

model Concept {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  tradition Tradition?
  summary   String?
  terms     Term[]
  claims    ClaimConcept[]
  refsFrom  CrossRef[] @relation("CrossRefFrom")
  refsTo    CrossRef[] @relation("CrossRefTo")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Term {
  id              String  @id @default(cuid())
  conceptId       String
  concept         Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  language        String  @default("en")
  name            String
  /// Glossary tier: one warm plain-language sentence or two.
  plainDefinition String
  /// Encyclopedia tier: the full treatment (markdown).
  deepDefinition  String?

  @@unique([conceptId, language, name])
  @@index([language, name])
}

model Claim {
  id         String          @id @default(cuid())
  /// Markdown body — one claim, one idea.
  body       String
  status     EpistemicStatus
  concepts   ClaimConcept[]
  citations  Citation[]
  /// QA pass: verified against sources & tone-checked.
  reviewedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model ClaimConcept {
  claimId   String
  conceptId String
  claim     Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade)
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([claimId, conceptId])
}

model Citation {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  // Point at the most specific thing available: an excerpt when one exists,
  // else an edition (with locator), else the source in general.
  excerptId String?
  excerpt   Excerpt? @relation(fields: [excerptId], references: [id])
  editionId String?
  edition   Edition? @relation(fields: [editionId], references: [id])
  sourceId  String?
  source    Source?  @relation(fields: [sourceId], references: [id])
  locator   String?
  note      String?
}

model CrossRef {
  id     String       @id @default(cuid())
  fromId String
  from   Concept      @relation("CrossRefFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId   String
  to     Concept      @relation("CrossRefTo", fields: [toId], references: [id], onDelete: Cascade)
  type   CrossRefType
  note   String?

  @@unique([fromId, toId, type])
}
